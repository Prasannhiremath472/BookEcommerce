# Copy this file to .env and fill in real values.
# Nothing in this server will work (DB connection, payments) until you do.

# --- Server ---
PORT=4000
# Local dev: http://localhost:5178 (or whatever port `npm run dev` uses in ../frontend)
# Production (Hostinger): your deployed site's exact origin, e.g. https://yourdomain.com
CORS_ORIGIN=http://localhost:5178

# --- JWT ---
# Any long random string. Generate one with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=30d

# --- MySQL (Hostinger) ---
# Found in hPanel -> Databases -> MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_USER=replace-with-hostinger-db-user
DB_PASSWORD=replace-with-hostinger-db-password
DB_NAME=replace-with-hostinger-db-name

# --- Razorpay ---
# From https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=replace-with-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret
