# Copy this file to .env and fill in real values.
# Nothing in this server will work (DB connection, email sending) until you do.

# --- Server ---
PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- JWT ---
# Any long random string. Generate one with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=30d

# --- MySQL (Hostinger) ---
# Found in hPanel -> Databases -> MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_USER=replace-with-hostinger-db-user
DB_PASSWORD=replace-with-hostinger-db-password
DB_NAME=replace-with-hostinger-db-name

# --- Mailjet ---
# From https://app.mailjet.com/account/apikeys
MAILJET_API_KEY=replace-with-mailjet-api-key
MAILJET_API_SECRET=replace-with-mailjet-api-secret
MAILJET_SENDER_EMAIL=replace-with-a-verified-sender-email@yourdomain.com
MAILJET_SENDER_NAME=Cosmos Edge

# --- OTP behavior ---
OTP_TTL_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=45
