# Copy to .env.local for local development.
# Points the frontend at the auth/payments API (see ../backend).
VITE_API_URL=http://localhost:4000
# In production (Hostinger), point this at your deployed backend's public URL, e.g.:
# VITE_API_URL=https://api.yourdomain.com
# or, if the backend runs on a Hostinger VPS/Node app on a subpath:
# VITE_API_URL=https://yourdomain.com:4000

# Razorpay public key id (safe for frontend). Never put the key secret here —
# that lives only in backend/.env and is used for order creation + signature verification.
VITE_RAZORPAY_KEY_ID=replace-with-razorpay-key-id
